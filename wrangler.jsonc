{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "asterisk",
  "compatibility_date": "2026-04-13",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "frontend"
  },
  "pages_build_output_dir": "frontend",
  "functions_dir": "frontend/functions",
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
